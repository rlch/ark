layout {
    tab name="{{ name }}" cwd="{{ cwd }}" {
        pane split_direction="vertical" {
            pane size="70%" name="agent" {
                command "{{ agent_cmd }}"
                {% for a in agent_args %}args "{{ a }}"
                {% endfor %}
            }
            pane name="diff" {
                command "ark"
                args "pane" "diff" "--cwd" "{{ cwd }}"
            }
        }
    }
}
