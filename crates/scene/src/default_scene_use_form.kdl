// ark v0.3 built-in default scene — `use` form (T-10.10).
//
// This is the post-T-10.10 shape of the default scene: instead of
// inline `plugin "picker" { … }` / `plugin "status" { … }` blocks
// (see `default_scene.kdl`), it activates the two shipped plugins
// through the extension surface (R10 / R11). Both forms compile to
// identical runtime behaviour — the inline form remains parseable
// indefinitely (Rust-editions / Neovim-Lua-shim convention).
//
// The scene compiler's built-in extension registry (post-v0.3)
// consumes this file. Until that registry lands, `default_scene.kdl`
// (inline form) is the authoritative fallback baked into the binary
// so the CLI boots on fresh machines with zero external state.

scene "default" {
    use "picker"
    use "status"

    keybind "Alt p" intent="ark.core.show_picker"
    keybind "Alt q" intent="ark.core.quit"
}
