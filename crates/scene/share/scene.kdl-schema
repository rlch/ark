// Generated by `cargo run -p ark-scene --bin gen-scene-schema`.
// DO NOT EDIT BY HAND. Source of truth: crates/scene/src/ast.rs
// (walked via facet SHAPE reflection).

document {
    info {
        title "ark scene file"
        description "Reactive KDL config for ark (cavekit-scene.md R1)."
        version "0.1.0-phase-a"
    }

    node "scene" {
        description "A `scene \"<name>\" { … }` block — root of the reactive-config AST.  Body admits the node set listed in R1: `extends`, `include`, `use`, `layout`, `plugin`, `on`, `keybind`, `engine`, `clear-reactions`, `clear-keybind`, `disable-plugin`. Node ordering is semantically irrelevant EXCEPT that `on` and `keybind` execute in textual order within a single scene file (R11 merge rules)."
        value "name" {
            description "Human-chosen scene name, supplied as the first positional argument (`scene \"<name>\" { … }`). Must be unique within a profile for `--scene NAME` selection (R-Design-Decisions \"Scene selection\")."
            type "string"
            min 1; max 1
        }
        prop "max-cascade-depth" {
            description "Max cascade depth for `emit` op chains (R4 acceptance criterion, `max-cascade-depth=<N>`). Default 4 when absent; exceeding at runtime is an error log + drop."
            type "u32"
            required #false
        }
        children {
            node "extends" {
                description "Zero or one `extends \"<scene-name>\"` child. R11: one `extends` per scene; parent contributions merge before child's."
                min 0; max 1
                ref "ExtendsNode"
            }
            node "include" {
                description "`include \"<path>\"` children. R11: splice another fragment at this position in load order. Multiple allowed."
                min 0
                ref "IncludeNode"
            }
            node "use" {
                description "`use \"<name>\"` children. R10 extension activation; transitive. One per named extension."
                min 0
                ref "UseNode"
            }
            node "layout" {
                description "`layout { … }` block (R3). Compiled to a zellij-compatible KDL file at spawn time. Optional: a scene may exist purely to add reactions or to `extends` a parent that supplies the layout."
                min 0; max 1
                ref "LayoutNode"
            }
            node "plugin" {
                description "`plugin \"<name>\" { … }` blocks (R6). Each declares a zellij wasm plugin lifecycle."
                min 0
                ref "PluginNode"
            }
            node "on" {
                description "`on \"<selector>\" { <ops> }` reactions (R4). Executed in textual order within this file; see R11 for cross-file ordering."
                min 0
                ref "OnNode"
            }
            node "keybind" {
                description "`keybind \"<chord>\" …` declarations (R5)."
                min 0
                ref "KeybindNode"
            }
            node "engine" {
                description "`engine { name \"…\"; command \"…\"; args … }` — direct ACP launch spec per R17. At most one; mutual-exclusion with `use \"engine-*\"` is enforced in the compile pipeline as `scene/engine-conflict`."
                min 0; max 1
                ref "EngineNode"
            }
            node "clear-reactions" {
                description "`clear-reactions selector=\"<sel>\"` entries (R11). Drops prior reactions matching the selector during merge."
                min 0
                ref "ClearReactionsNode"
            }
            node "clear-keybinds" {
                description "`clear-keybind \"<chord>\"` entries (R11). Drops prior keybind on the named chord."
                min 0
                ref "ClearKeybindNode"
            }
            node "disable-plugins" {
                description "`disable-plugin \"<name>\"` entries (R10). Suppresses an extension-contributed auto-mount."
                min 0
                ref "DisablePluginNode"
            }
        }
    }

    definitions {
        node id="ClearKeybindNode" {
            description "`clear-keybind \"<chord>\"` — drops a prior keybind on the named chord (R11)."
            value "chord" {
                description "Chord to clear."
                type "string"
                min 1; max 1
            }
        }
        node id="ClearReactionsNode" {
            description "`clear-reactions selector=\"<sel>\"` — drops prior reactions matching the selector during merge (R11)."
            prop "selector" {
                description "Selector to clear. Same grammar as R4 selectors."
                type "string"
                required #true
            }
        }
        node id="DisablePluginNode" {
            description "`disable-plugin \"<name>\"` — suppresses an extension-contributed plugin auto-mount (R10)."
            value "name" {
                description "Plugin name to disable."
                type "string"
                min 1; max 1
            }
        }
        node id="DismissNode" {
            description "`dismiss \"<event-selector>\"` child of a `plugin { }` block — closes a summon/event-mount plugin when the selector matches (R6)."
            value "selector" {
                description "Event selector to close on."
                type "string"
                min 1; max 1
            }
        }
        node id="EngineArgsNode" {
            description "`args \"<v1>\" \"<v2>\" …` child of `engine { }` — positional argv entries appended after `command`. Multiple `args` lines are permitted and flattened in source order during lowering."
            value "values" {
                description "The argv strings on this line, in source order."
                type "string"
                min 0
            }
        }
        node id="EngineEnvNode" {
            description "`env { KEY \"VAL\"; … }` child of `engine { }` — environment-variable bag. Each [`EngineEnvVarNode`] is a single variable (node name = key, first argument = value)."
            children {
                node "var" {
                    description "Ordered list of env-var entries (preserves source order so duplicate-key diagnostics can point at the second occurrence). Children carry arbitrary node names (the env-var keys); the `kdl::children` routing accepts every node, with each one captured as an [`EngineEnvVarNode`] via `kdl::node_name`."
                    min 0
                    ref "EngineEnvVarNode"
                }
            }
        }
        node id="EngineEnvVarNode" {
            description "One `KEY \"VAL\"` line inside `engine { env { … } }`.  `kdl::node_name` captures the env-var name (allowing arbitrary identifier shapes — UPPER_SNAKE, mixedCase, kebab-case, quoted strings with spaces, etc.). The first positional argument carries the value."
            value "value" {
                description "The env-var value (first positional argument)."
                type "string"
                min 1; max 1
            }
        }
        node id="EngineNode" {
            description "`engine { name \"…\"; command \"…\"; args \"…\"; env { … } }` — direct ACP launch spec per R17. At most one per scene. Mutual-exclusion with `use \"engine-*\"` enforced in the compile pipeline (`scene/engine-conflict`).  The compile pipeline lowers this into [`crate::ops::EngineLaunch`] (see also [`crate::path`] for scene resolution); this AST shape preserves source fidelity for span-rich diagnostics."
            children {
                node "name" {
                    description "Human-friendly engine identifier (e.g. `\"claude\"`). Surfaces in `ark scene graph` attribution."
                    min 0; max 1
                    ref "EngineStringNode"
                }
                node "command" {
                    description "Argv-0 of the engine process."
                    min 0; max 1
                    ref "EngineStringNode"
                }
                node "args" {
                    description "Additional argv entries. Each `args \"<v1>\" \"<v2>\" …` line in the source contributes one [`EngineArgsNode`] whose `values` vector holds the positional strings on that line. Multiple `args` lines are allowed and concatenated in source order; the lowering step (T-ACP.3 / [`crate::engine::lower_engine`]) flattens them into a single argv slice.  Renamed to `\"args\"` (matching the field name verbatim, which is also the spec form per R17) so the generated KDL schema announces the correct node name. Without the rename the schema-emitter would singularize `args` → `arg`; facet-kdl's runtime accepts `args` regardless, but the schema would lie to editor tooling."
                    min 0
                    ref "EngineArgsNode"
                }
                node "env" {
                    description "`env { KEY \"VAL\" }` block (R17). Each child is a single environment variable: child node name = env-var key, first positional argument = value. Allows arbitrary key names by routing through `kdl::node_name`."
                    min 0; max 1
                    ref "EngineEnvNode"
                }
            }
        }
        node id="EngineStringNode" {
            description "Shared shape for single-argument string children inside `engine { }` (e.g. `name \"claude\"` or `command \"claude\"`)."
            value "value" {
                description "The string value (first positional argument)."
                type "string"
                min 1; max 1
            }
        }
        node id="ExtendsNode" {
            description "`extends \"<parent-scene>\"` — inherits a base scene (R11). At most one per scene file. Child overrides parent per the merge rules documented in R11."
            value "parent" {
                description "Name of the parent scene to inherit from. Resolution goes through the same scene search path as `--scene NAME` (see Design-Decisions \"Scene selection\")."
                type "string"
                min 1; max 1
            }
        }
        node id="IncludeNode" {
            description "`include \"<path>\"` — splices another KDL fragment at this point in load order (R11). Multiple `include` nodes allowed per scene; they are applied in source position."
            value "path" {
                description "Path (relative to the current scene file) of the fragment to splice. Cycle detection raises `scene/include-cycle` (R12)."
                type "string"
                min 1; max 1
            }
        }
        node id="KeybindNode" {
            description "`keybind \"<chord>\" [intent=\"<name>\"] [{ <op>+ }]` — keybind declaration (R5). Two legal shapes: the `intent=` shorthand and the block form carrying ops in the body."
            value "chord" {
                description "The chord string, e.g. `\"Alt p\"`. Validated against zellij's key chord lexer at compile time."
                type "string"
                min 1; max 1
            }
            prop "intent" {
                description "Shorthand: `intent=\"<name>\"` dispatches a single intent. Legal on `keybind` only (R2). Mutually exclusive with a non-empty body."
                type "string"
                required #false
            }
            children {
                node "op" {
                    description "Block-form op list. Same op grammar as `on { }` reaction bodies."
                    min 0
                    ref "OpNode"
                }
            }
        }
        node id="LayoutNode" {
            description "`layout { … }` — preprocessed superset of zellij's layout KDL (R3). The compiler renders it to a zellij-compatible KDL file at spawn.  Note: the full zellij layout grammar is large (tab templates, swap layouts, floating panes, pane templates, stacked panes, …). This v1 AST enumerates only the nodes that scene-level scope rules (R2) reference: `tab` and `pane`. Any additional zellij-native attributes pass through untouched via the catch-all raw-argument bag — see the `extra` field on `TabNode` / `PaneNode`."
            children {
                node "tab" {
                    description "`tab \"<name>\" { … }` children. Multiple allowed; iteration order matches zellij's layout semantics."
                    min 0
                    ref "TabNode"
                }
                node "pane" {
                    description "Top-level `pane { … }` children (rare — most panes live inside a `tab`, but zellij allows layout-level panes)."
                    min 0
                    ref "PaneNode"
                }
            }
        }
        node id="MountNode" {
            description "`mount <target> <key=val>*` child of a `plugin { }` block (R6). Positional attrs: `into`, `split`, `size`, `x`, `y`, `width`, `height`."
            value "target" {
                description "Mount target: one of `status-bar`, `floating`, `pane`, `hidden`."
                type "string"
                min 1; max 1
            }
            prop "into" {
                description "Named pane slot to fill (`into=\"<slot>\"`)."
                type "string"
                required #false
            }
            prop "split" {
                description "`split` direction when mounting to `pane`."
                type "string"
                required #false
            }
            prop "size" {
                description "Size (percent or cell count)."
                type "string"
                required #false
            }
            prop "x" {
                description "X coordinate for `floating` mounts."
                type "string"
                required #false
            }
            prop "y" {
                description "Y coordinate for `floating` mounts."
                type "string"
                required #false
            }
            prop "width" {
                description "Width for `floating` mounts."
                type "string"
                required #false
            }
            prop "height" {
                description "Height for `floating` mounts."
                type "string"
                required #false
            }
        }
        node id="OnNode" {
            description "`on \"<event-selector>\" [if=\"<CEL>\"] { <op>+ }` — reaction declaration at scene root (R4). Distinct from `PluginOnNode`, which is a lifecycle marker inside `plugin { }`."
            value "selector" {
                description "Event selector. Grammar per R4."
                type "string"
                min 1; max 1
            }
            prop "if" {
                description "Optional `if=\"<CEL>\"` predicate. Legal on `on` only (R2)."
                type "string"
                required #false
            }
            children {
                node "op" {
                    description "Ordered op list in the reaction body. Op vocabulary is R7; each `OpNode` is an opaque name + raw KDL entries until T-3.x nails down the typed surface."
                    min 0
                    ref "OpNode"
                }
            }
        }
        node id="OpNode" {
            description "Opaque op node inside an `on { }` or `keybind { }` body.  R7 defines ~17 canonical ops (`open_tab`, `split_pane`, `emit`, `pipe`, `prompt`, `acp/cancel`, …). Each has a distinct schema. Encoding all of them as a typed enum is T-3.2 work; for T-0.2 we keep the AST open by retaining a free-form name + argument bag that the compile pipeline re-parses against the typed op registry."
            value "args" {
                description "Positional arguments to the op, in source order."
                type "string"
                min 0
            }
        }
        node id="OpaqueBlock" {
            description "Untyped KDL block placeholder for sub-grammars not yet schematized (e.g. `config { … }` bodies, `args { … }` inside `engine { }`). The compile pipeline re-parses these with the right schema once the owning extension or plugin is resolved.  TODO(T-3.x / T-4.x): replace each call site with a typed node once the extension-manifest and op schemas land."
            value "args" {
                description "Catch-all positional args (if any)."
                type "string"
                min 0
            }
        }
        node id="Option" {
        }
        node id="PaneNode" {
            description "`pane { … }` or `pane \"<cmd>\"` — zellij pane declaration with ark-added `when=` predicate (R2). Command, args, cwd, size, and split-direction are zellij pass-throughs."
            prop "when" {
                description "`when=\"<CEL>\"` predicate (R3). Same semantics as `TabNode::when`."
                type "string"
                required #false
            }
            prop "name" {
                description "Pane display name (zellij `name=…`)."
                type "string"
                required #false
            }
            prop "command" {
                description "Shell command to run in the pane."
                type "string"
                required #false
            }
            prop "size" {
                description "Pane size (percent or cell count — zellij parses the suffix). Kept as `String` at the AST layer so both `50` and `\"50%\"` round-trip."
                type "string"
                required #false
            }
            prop "split_direction" {
                description "Split direction (zellij `split_direction`). Kept as `String` because zellij accepts several spellings (`vertical`, `horizontal`, `v`, `h`)."
                type "string"
                required #false
            }
            prop "focus" {
                description "Zellij focus flag."
                type "bool"
                required #false
            }
            prop "cwd" {
                description "Working directory at launch."
                type "string"
                required #false
            }
            children {
                node "pane" {
                    description "Nested panes (zellij recursion)."
                    min 0
                    ref "PaneNode"
                }
            }
        }
        node id="PluginNode" {
            description "`plugin \"<name>\" { … }` — zellij wasm plugin declaration (R6).  Note: `plugin` references ONLY zellij wasm cartridges. ark-native extensions use `use \"<name>\"` (R10 / `UseNode`). The two keywords are NOT interchangeable; the compile pipeline enforces the separation."
            value "name" {
                description "Plugin name, first positional argument."
                type "string"
                min 1; max 1
            }
            prop "override" {
                description "`override=true` lets a user scene replace an extension-contributed default plugin block without a duplicate-decl error (R6)."
                type "bool"
                required #false
            }
            children {
                node "source" {
                    description "`source` child (required): one of `shipped:<name>`, `ext:<name>`, `file:<path>`, `url:<…>`."
                    min 0; max 1
                    ref "SourceNode"
                }
                node "mount" {
                    description "`mount` child (required): target = status-bar | floating | pane | hidden, plus positional attrs."
                    min 0; max 1
                    ref "MountNode"
                }
                node "summon" {
                    description "`summon \"<selector>\"` — lifecycle marker (summon-mode plugin). Presence along with `on` is `scene/plugin-ambiguous-lifecycle`."
                    min 0; max 1
                    ref "SummonNode"
                }
                node "dismiss" {
                    description "`dismiss \"<selector>\"` — close selector for summon/event-mount plugins."
                    min 0; max 1
                    ref "DismissNode"
                }
                node "on" {
                    description "`on \"<event-selector>\"` inside a plugin body — lifecycle marker (event-mount-mode plugin). See R6 and `PluginOnNode`."
                    min 0
                    ref "PluginOnNode"
                }
                node "subscribe" {
                    description "`subscribes \"<selector>\"` children — events forwarded via `zellij pipe --plugin <url>` regardless of mount state."
                    min 0
                    ref "SubscribesNode"
                }
                node "config" {
                    description "Optional `config { … }` block validated against the plugin's declared schema. Untyped at AST layer; see UseNode::config."
                    min 0; max 1
                    ref "OpaqueBlock"
                }
            }
        }
        node id="PluginOnNode" {
            description "`on \"<event-selector>\"` child of a `plugin { }` block — lifecycle marker making the plugin event-mounted (R6). Distinct from the scene-root `on { }` reaction node (see `OnNode`)."
            value "selector" {
                description "Event selector to mount on."
                type "string"
                min 1; max 1
            }
        }
        node id="SourceNode" {
            description "`source \"<uri>\"` child of a `plugin { }` block (R6). URI formats: `shipped:<name>`, `ext:<name>`, `file:<path>`, `url:<https://…>`."
            value "uri" {
                description "The source URI string, validated at compile time."
                type "string"
                min 1; max 1
            }
        }
        node id="SubscribesNode" {
            description "`subscribes \"<event-selector>\"` child of a `plugin { }` block — forwards matching events to the plugin via `zellij pipe` regardless of mount state (R6)."
            value "selector" {
                description "Selector string."
                type "string"
                min 1; max 1
            }
        }
        node id="SummonNode" {
            description "`summon \"<event-selector>\"` child of a `plugin { }` block — dormant plugin activated on first selector match (R6)."
            value "selector" {
                description "Event selector string. Same grammar as the top-level `on` selector (R4): `<EventKind>`, `<EventKind> field=\"val\"` (sugar), or `UserEvent:<namespaced-name>`."
                type "string"
                min 1; max 1
            }
        }
        node id="TabNode" {
            description "`tab \"<name>\" { … }` — zellij tab declaration with ark-added `when=` predicate (R2, R3). Attributes ark does not own pass through unchanged to the rendered layout."
            value "name" {
                description "Optional tab name (first positional arg if supplied). Zellij treats missing names as index-only."
                type "string"
                min 0; max 1
            }
            prop "when" {
                description "`when=\"<CEL>\"` predicate (R3). Evaluated against initial agent state at compile time; false = prune branch before emission. Legal only on `tab` / `pane` per R2."
                type "string"
                required #false
            }
            prop "focus" {
                description "`focus=#true/#false` — zellij pass-through."
                type "bool"
                required #false
            }
            children {
                node "pane" {
                    description "Nested `pane { … }` children."
                    min 0
                    ref "PaneNode"
                }
            }
        }
        node id="UseNode" {
            description "`use \"<ext-name>\"` — activates an ark-native extension (R10). May carry an optional `config { … }` block validated against the extension's declared schema."
            value "name" {
                description "Extension name. Resolved via the R10 search path (`./.ark/extensions/…`, `${XDG_DATA_HOME}/ark/extensions/…`, `/usr/share/ark/extensions/…`, built-in)."
                type "string"
                min 1; max 1
            }
            children {
                node "config" {
                    description "Optional `config { … }` block. Contents are untyped at this AST layer — the extension declares a schema that's applied during the compile pipeline. Represented as a catch-all `OpaqueBlock` so the facet-kdl derive compiles without the schema known statically."
                    min 0; max 1
                    ref "OpaqueBlock"
                }
            }
        }
    }
}
