                    plural #false
                    required #false
                }
            }
            result {
                field "status" {
                    description "HTTP status code."
                    type "u16"
                    plural #false
                    required #true
                }
                field "body" {
                    description "Response body."
                    type "string"
                    plural #false
                    required #true
                }
            }
        }

        // -- Logging --
        method "log/write" {
