            result {
                field "contents" {
                    description "File contents as a UTF-8 string. Non-UTF-8 files surface as [`ExtensionError::InvalidParams`] — use a future `host/fs/readBytes` for binary content (added as MINOR bump per R16 rule #1)."
                    type "string"
                    plural #false
                    required #true
